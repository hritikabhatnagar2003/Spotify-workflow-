# ── Environment ──────────────────────────────────────────────

# Groq API (for fast LLM inference via the cloud — replaces local Ollama for generation)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Target Spotify App IDs (no API key needed — scraped directly)
SPOTIFY_APPSTORE_ID=324684580
SPOTIFY_PLAYSTORE_ID=com.spotify.music

# Maximum reviews to fetch per platform per run
MAX_REVIEWS=500

# Ollama (local — handles embeddings; LLM can be swapped to Groq)
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: Groq LLM model to use (if using Groq for RAG generation)
GROQ_LLM_MODEL=llama-3.1-8b-instant

# API Server
PORT=3001
